{
    "name": "Python Dev Container",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",  
    "postCreateCommand": "sudo pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "monosans.djlint",
                "samuelcolvin.jinjahtml"
            ]
        }
    }
}
