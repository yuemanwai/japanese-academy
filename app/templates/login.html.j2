{% extends "base.html.j2" %}
{% import 'bootstrap/wtf.html' as wtf %}
{% block app_content %}
<div class="login-container">
    <div class="login-box">
        <h2><b>{{ title }}</b></h2>
        {{ wtf.quick_form(form) }}
        <br />
        <p>
            <a href="{{ url_for('reset_password_request') }}">{{ _("Forgot your password?") }}</a>
        </p>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 70vh;
    }

    .login-box {
        background-color: #333;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
        color: white;
        width: 500px;
    }

    .login-box h2 {
        text-align: center;
        margin-bottom: 20px;
    }

    .login-box a {
        color: whitesmoke;
    }

    .login-box a:hover {
        color: whitesmoke;
        text-decoration: underline;
    }
</style>
{% endblock app_content %}
