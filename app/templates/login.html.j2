{% extends "base.html.j2" %}
{% import 'bootstrap/wtf.html' as wtf %}
{% block app_content %}
<div class="login-container">
    <div class="login-box glass-panel">
        <h2><b>{{ title }}</b></h2>
        {{ wtf.quick_form(form) }}
        <br />
        <p>
            <a href="{{ url_for('reset_password_request') }}">{{ _("Forgot your password?") }}</a>
        </p>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 70vh;
        background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)),
                    url('https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=1600') center/cover fixed;
    }

    .login-box {
        max-width: 500px;
        width: 90%;
        padding: 2rem;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        color: white;
        position: relative;
        overflow: hidden;
    }

    .login-box:hover {
        background-color: rgba(255, 255, 255, 0.15);
    }

    .login-box h2 {
        margin-bottom: 1.5rem;
        font-size: 1.8rem;
    }

    .login-box a {
        color: whitesmoke;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .login-box a:hover {
        color: #ffd7e6;
        text-decoration: underline;
    }
</style>
{% endblock app_content %}
