{% extends "base.html.j2" %}
{% import 'bootstrap/wtf.html' as wtf %}
{% block app_content %}
<div class="login-container">
    <div class="login-box glass-panel">
        <h2><b>{{ title }}</b></h2>
        {{ wtf.quick_form(form) }}
        <br />
        <p>
            <a href="{{ url_for('reset_password_request') }}">{{ _("Forget password") }}</a>
        </p>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
        border-radius: 15px;
        background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)),
                    url('{{ url_for("static", filename="image/hero-background.png") }}') center/cover fixed;
    }

    .login-box {
        max-width: 500px;
        width: 90%;
        padding: 2rem;
        border-radius: 1rem;
        background: var(--bg-secondary);
        box-shadow: var(--card-shadow);
        color: var(--text-primary);
        position: relative;
        overflow: hidden;
        transition: background-color 0.3s ease, box-shadow 0.3s ease;
    }

    .login-box:hover {
        box-shadow: var(--card-shadow-hover);
    }

    .login-box h2 {
        margin-bottom: 1.5rem;
        font-size: 1.5rem; /* 調整登入標題字體大小 */
        color: var(--text-primary);
        font-weight: 600;
    }

    .login-box a {
        color: var(--accent-blue);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .login-box a:hover {
        color: var(--accent-pink);
        text-decoration: underline;
    }

    .form .form-group label, .checkbox label {
        text-align: left;
        display: block; 
    }

    .checkbox {
        margin-top: 20px; 
    }

    .form .form-group {
        text-align: left;
    }

    .btn {
        margin: 15px 0pc 0px 0px;
        padding: 1rem;
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        padding: 8px 32px;
    }

    #remember_me {
        transform: scale(1.3);
    }

</style>
{% endblock app_content %}
