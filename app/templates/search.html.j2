{% extends "base.html.j2" %}

{% block app_content %}
<div class="search-container">
  <div class="search-box glass-panel">
    <div class="section-title">
      <h1>{{ _('Search') }}</h1>
    </div>
    
    <form class="search-form" action="{{ url_for('search') }}" method="post">
      {{ g.search_form.hidden_tag() }}
      <div class="search-input-group">
        {{ g.search_form.keyword(class="form-control search-input", placeholder=keyword, aria_label="Search") }}
        <button class="btn btn-primary search-btn" type="submit">
          <i class="fa fa-search"></i>
          {{_('Search') }}
        </button>
      </div>
    </form>

    {% if posts %}
    <div class="search-results">
      <div class="results-header">
        <p><strong>{{_('There is a page named "') }}{{keyword}}{{_('" on Wikipedia') }}</strong></p>
      </div>
      
      <div class="results-list">
        {% for post in posts %}
        <div class="result-item glass-panel">
          <h3>{{ post.title }}</h3>
          <p>{{ post.body }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
    {% else %}
    <div class="no-results">
      <p>{{_('No results found.')}}</p>
    </div>
    {% endif %}

    <nav class="search-pagination">
      <ul class="pagination-list">
        <li class="pagination-item{% if not prev_url %} disabled{% endif %}">
          <a href="{{ prev_url or '#' }}" class="pagination-link">
            <i class="fa fa-arrow-left"></i>
            {{ _('previous posts') }}
          </a>
        </li>
        <li class="pagination-item{% if not next_url %} disabled{% endif %}">
          <a href="{{ next_url or '#' }}" class="pagination-link">
            {{ _('Next posts') }}
            <i class="fa fa-arrow-right"></i>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>

<style>
  .search-container {
    min-height: 80vh;
    padding: 2rem 0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .search-box {
    max-width: 900px;
    width: 90%;
    padding: 2.5rem;
  }

  .search-form {
    margin: 2rem 0;
  }

  .search-input-group {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .search-input {
    flex: 1;
    padding: 1rem;
    font-size: 1.1rem;
    border-radius: 8px;
    border: 2px solid var(--accent-blue);
    background-color: var(--bg-primary);
    color: var(--text-primary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent-pink);
    box-shadow: 0 0 0 0.2rem rgba(255, 0, 110, 0.25);
  }

  .search-btn {
    padding: 1rem 2rem;
    white-space: nowrap;
  }

  .search-btn i {
    margin-right: 0.5rem;
  }

  .search-results {
    margin: 3rem 0;
  }

  .results-header {
    margin-bottom: 2rem;
  }

  .results-header p {
    font-size: 1.2rem;
    color: var(--accent-blue);
  }

  .results-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .result-item {
    padding: 2rem;
    margin: 0;
  }

  .result-item h3 {
    color: var(--accent-blue);
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .result-item p {
    color: var(--text-primary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .no-results {
    text-align: center;
    margin: 3rem 0;
  }

  .no-results p {
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .search-pagination {
    margin-top: 3rem;
  }

  .pagination-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pagination-item {
    flex: 1;
  }

  .pagination-item.disabled .pagination-link {
    opacity: 0.5;
    pointer-events: none;
  }

  .pagination-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    color: var(--accent-blue);
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .pagination-link:hover {
    color: var(--accent-pink);
    text-decoration: none;
  }

  .pagination-item:last-child .pagination-link {
    justify-content: flex-end;
  }

  @media (max-width: 600px) {
    .search-input-group {
      flex-direction: column;
    }
    
    .search-input,
    .search-btn {
      width: 100%;
    }
    
    .pagination-list {
      flex-direction: column;
      gap: 1rem;
    }
    
    .pagination-item:last-child .pagination-link {
      justify-content: center;
    }
  }
</style>
{% endblock %}