{% extends "base.html.j2" %}
{% import 'bootstrap/wtf.html' as wtf %}
{% block app_content %}
<div class="register-container">
    <div class="register-box glass-panel">
        <h2><b>{{ title }}</b></h2>
        {{ wtf.quick_form(form) }}
        <br />
    </div>
</div>

<style>
    .register-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
        border-radius: 15px; /* 邊框圓角 */
        background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)),
                    url('https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=1600') center/cover fixed;
    }

    .register-box {
        max-width: 500px;
        width: 90%;
        padding: 2rem;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        color: white;
        position: relative;
        overflow: hidden;
    }

        .register-box:hover {
        background-color: rgba(255, 255, 255, 0.15);
    }

    .register-box h2 {
        margin-bottom: 1.5rem;
        font-size: 1.8rem;
    }

    .register-box a {
        color: whitesmoke;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .register-box a:hover {
        color: #ffd7e6;
        text-decoration: underline;
    }

    .form .form-group label, .checkbox label {
        text-align: left;
        display: block; 
    }

    .checkbox {
    margin-top: 20px; 
    }

    .form .form-group {
        text-align: left;
    }

    .btn {
        margin: 15px 0pc 0px 0px;
        padding: 1rem;
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        padding: 8px 32px;
    }

</style>
{% endblock app_content %}