{% extends 'base.html.j2' %}

{% block head %}
{{ super() }}
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
<style>
  .dictionary-container {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 0;
  }
  
.dictionary-card {
  background: var(--bg-secondary);
  border-radius: 15px;
  padding: 2.5rem;
  margin: 2rem 0;
  box-shadow: var(--card-shadow);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  color: var(--text-primary);
  max-width: 800px;
  width: 90%;
}

.dictionary-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--card-shadow-hover);
}

.dictionary-title {
  color: var(--accent-blue);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 1.8rem;
  font-weight: 600;
}

.feature-box {
  background: rgba(58, 134, 255, 0.1);
  padding: 1.5rem;
  border-radius: 10px;
  margin: 1.5rem 0;
  color: var(--text-primary);
  border-left: 4px solid var(--accent-blue);
}

.objective {
  border-left: 4px solid var(--secondary);
  padding-left: 1rem;
  margin: 1rem 0;
  color: var(--dark);
}

.practice-area {
  background: white;
  border: 2px dashed var(--primary);
  border-radius: 8px;
  padding: 2rem;
  margin: 1rem 0;
  text-align: center;
}

.btn {
  background: var(--primary);
  color: white;
  border: none;
  padding: 0.8rem 1.5rem;
  border-radius: 25px;
  cursor: pointer;
  transition: background 0.3s ease;
}

.btn:hover {
  background: var(--secondary);
}

.kana-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
  margin: 2rem 0;
}

.kana-character {
  background: white;
  padding: 1rem;
  border-radius: 8px;
  text-align: center;
  cursor: pointer;
  color: var(--dark);
}

.canvas-container {
  width: 400px;
  height: 400px;
  margin: 0 auto;
}
</style>
{% endblock head %}

{% block app_content %}
<div class="dictionary-container">
  <div class="container">
    <!-- Dictionary Section -->
    <div class="dictionary-card">
      <h2 class="dictionary-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <text x="50%" y="50%" text-anchor="middle" dy=".3em" fill="currentColor">D</text>
        </svg>
        Japanese Dictionary
      </h2>
      
      <div class="feature-box">
        <h3>Search for Words</h3>
        <input type="text" class="form-control" placeholder="Enter a word to search...">
        <button class="btn" onclick="searchWord()">Search</button>
      </div>

      <div class="objective">
        <h4>Dictionary Objective:</h4>
        <p>Find meanings, pronunciations, and examples of Japanese words.</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
{{ super() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
function searchWord() {
  alert('Search functionality will be implemented here.');
}

// Add some animation on page load
gsap.from('.dictionary-card', {
  y: 50,
  opacity: 0,
  duration: 1,
  stagger: 0.2,
  ease: 'power2.out'
});
</script>
{% endblock scripts %}