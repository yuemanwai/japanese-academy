{% extends 'base.html.j2' %}

{% block head %}
{{ super() }}
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@2.1.1/dist/tesseract.min.js"></script> <!-- Add Tesseract.js for OCR -->
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
<style>
  .lesson-container {
    background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('https://images.unsplash.com/photo-1549693578-d683be217e58?w=1600') center/cover fixed;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
    border-radius: 15px; /* 邊框圓角 */
  }
  
.lesson-card {
  background: white;
  border-radius: 15px;
  padding: 2rem;
  margin: 2rem 0;
  box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  transition: transform 0.3s ease;
}

.lesson-card:hover {
  transform: translateY(-5px);
}

.lesson-title {
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}

.feature-box {
  padding: 1rem;
  border-radius: 8px;
  margin: 1rem 0;
  background-color: transparent; 
}

.objective {
  border-left: 4px solid var(--secondary);
  padding-left: 1rem;
  margin: 1rem 0;
  text-align: left;
}

.practice-areas-container {
  display: flex;
  gap: 1rem;
  justify-content: space-between;
}

.practice-area {
  flex: 0 0 50%; /* Ensure equal width for both sections */
  box-sizing: border-box;
}

.practice-area {
  background: white;
  border: 2px dashed var(--secondary);
  border-radius: 8px;
  padding: 2rem;
  margin: 1rem 0;
  text-align: center;
}

#targetWord {
  font-size: 10rem; /* Increase font size */
  color: var(--dark); /* Set color to dark */
}

.btn {
  background: var(--secondary);
  color: var(--dark);
  border: none;
  padding: 0.8rem 1.5rem;
  border-radius: 25px;
  cursor: pointer;
  transition: background 0.3s ease;
}

.btn:hover {
  background: var(--secondary);
}

.kana-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
  margin: 2rem 0;
}

.canvas-container {
  width: 100%;
  height: 100%;
  margin: 0 auto;
}

#responseBlock {
  text-align: left;
}

.glass-button {
  padding: 1rem;
  border-radius: 8px;
  text-align: center;
  cursor: pointer;
}
.glass-panel h3{
  text-align: left;
}

.glass-panel:hover {
  background-color: rgba(255, 255, 255, 0.06);
}


</style>
<script>
  // Move the hiragana array definition here so it is available globally
  const hiragana = [
    'あ', 'い', 'う', 'え', 'お',
    'か', 'き', 'く', 'け', 'こ',
    'さ', 'し', 'す', 'せ', 'そ',
    'た', 'ち', 'つ', 'て', 'と',
    'な', 'に', 'ぬ', 'ね', 'の'
  ];
</script>
{% endblock head %}

{% block app_content %}
<div class="lesson-container">
  <div class="container">
    <!-- Lesson 1 -->
    <div class="glass-panel" id="lesson1">
      <h2 class="lesson-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <text x="50%" y="50%" text-anchor="middle" dy=".3em" fill="currentColor">1</text>
        </svg>
        Lesson 1: Mastering Hiragana and Katakana
      </h2>
      
      <div class="feature-box">
        <h3>50 Sounds Practice</h3>
        <div class="kana-grid" id="hiraganaGrid">
          <!-- JavaScript will populate this -->
        </div>
        <button class="glass-button" onclick="playSound(this)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M12 2v20M2 12h20"/>
          </svg>
          Listen to Pronunciation
        </button>
      </div>

      <div class="objective">
        <h4>Lesson Objective:</h4>
        <p>By the end of this lesson, you will be able to recognize and pronounce all 50 sounds.</p>
      </div>
    </div>

    <!-- Lesson 2 -->
    <div class="glass-panel" id="lesson2">
      <h2 class="lesson-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <text x="50%" y="50%" text-anchor="middle" dy=".3em" fill="currentColor">2</text>
        </svg>
        Lesson 2: Handwriting Practice
      </h2>
      <div class="practice-areas-container">
        <div class="practice-area">
            <div id="targetWord" class="glass-button">
            <script>
              const randomHiragana = hiragana[Math.floor(Math.random() * hiragana.length)];
              document.write(randomHiragana);
            </script>
            </div>
        </div>
        <div class="practice-area">
          <div class="canvas-container">
            <canvas id="handwritingPad"></canvas>
          </div>
          <div>
            <button class="btn" onclick="clearCanvas()">Clear</button>
            <button class="btn" onclick="recognizeCharacter()">Check Character</button>
          </div>
        </div>
      </div>

      <!-- Response Block -->
      <div id="responseBlock">
        <!-- Response will be dynamically inserted here -->
      </div>
    </div>

<!-- Lesson 3 -->
<div class="glass-panel" id="lesson3">
  <h2 class="lesson-title">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <text x="50%" y="50%" text-anchor="middle" dy=".3em" fill="currentColor">3</text>
    </svg>
    Lesson 3: Grammar Essentials
  </h2>
  
  <div class="feature-box">
    <h3>Basic Grammar Structure</h3>
    <p>Topic は Subject が Verb です</p>
    <button class="btn" onclick="searchGrammarExamples()">Find More Examples</button>
  </div>

  <div class="feature-box">
    <h3>Scenario Practice</h3>
    <p>Click the button below to generate a scenario, learn suitable grammar and vocabulary, and see a related photo.</p>
    <button class="btn" onclick="generateScenario()">Generate Scenario</button>
    <div id="scenarioOutput" style="margin-top: 1rem; padding: 1rem; border: 1px solid #ccc; border-radius: 8px; background-color: #f9f9f9;">
      <!-- Scenario content will be dynamically inserted here -->
      <script>
function generateScenario() {
  const scenarios = [
    {
      scenario: "You are introducing yourself to a new friend.",
      grammar: "私の名前は [Your Name] です。",
      vocab: "名前 (なまえ) - Name, 友達 (ともだち) - Friend",
      image: "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=MnwzNjUyOXwwfDF8c2VhcmNofDF8fGZyaWVuZHNoaXB8ZW58MHx8fHwxNjgyMDYyNjQw&ixlib=rb-4.0.3&q=80&w=300"
    },
    {
      scenario: "You are ordering food at a restaurant.",
      grammar: "すみません、[Dish Name] をください。",
      vocab: "すみません - Excuse me, をください - Please give me",
      image: "https://images.unsplash.com/photo-1551218808-94e220e084d2?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=MnwzNjUyOXwwfDF8c2VhcmNofDJ8fHJlc3RhdXJhbnR8ZW58MHx8fHwxNjgyMDYyNjQw&ixlib=rb-4.0.3&q=80&w=300"
    },
    {
      scenario: "You are asking for directions to the train station.",
      grammar: "[Place] はどこですか？",
      vocab: "どこ - Where, 駅 (えき) - Station",
      image: "https://images.unsplash.com/photo-1518684079-0e2e93191b4d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=MnwzNjUyOXwwfDF8c2VhcmNofDF8fHRyYWluJTIwc3RhdGlvbnxlbnwwfHx8fDE2ODIwNjI2NDA&ixlib=rb-4.0.3&q=80&w=300"
    }
  ];

  const randomScenario = scenarios[Math.floor(Math.random() * scenarios.length)];
  const scenarioOutput = document.getElementById('scenarioOutput');

  // Apply semi-transparent background dynamically
  scenarioOutput.style.backgroundColor = "rgba(255, 255, 255, 0.5)";
  scenarioOutput.style.padding = "1rem";
  scenarioOutput.style.border = "1px solid #ccc";
  scenarioOutput.style.borderRadius = "8px";

  scenarioOutput.innerHTML = `
    <p style="color: #000;"><strong style="color: #000;">Scenario:</strong> ${randomScenario.scenario}</p>
    <p style="color: #000;"><strong style="color: #000;">Grammar:</strong> ${randomScenario.grammar}</p>
    <p style="color: #000;"><strong style="color: #000;">Vocabulary:</strong> ${randomScenario.vocab}</p>
    <img src="${randomScenario.image}" alt="Scenario Image" style="width: 100%; max-width: 300px; border-radius: 8px; margin-top: 1rem;">
  `;
}
      </script>
    </div>
  </div>
</div>


{% endblock %}

{% block scripts %}
{{ super() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
// Populate Hiragana grid
const hiraganaGrid = document.getElementById('hiraganaGrid');
hiragana.forEach(char => {
  const div = document.createElement('div');
  div.className = 'glass-button';
  div.textContent = char;
  div.onclick = () => playCharacterSound(char);
  hiraganaGrid.appendChild(div);
});

// Canvas setup for handwriting
const canvas = document.getElementById('handwritingPad');
const ctx = canvas.getContext('2d');
let isDrawing = false;
let lastX = 0;
let lastY = 0;

ctx.strokeStyle = '#000';
ctx.lineJoin = 'round';
ctx.lineCap = 'round';
ctx.lineWidth = 8;

canvas.addEventListener('mousedown', startDrawing);
canvas.addEventListener('mousemove', draw);
canvas.addEventListener('mouseup', stopDrawing);
canvas.addEventListener('mouseout', stopDrawing);

function startDrawing(e) {
  isDrawing = true;
  [lastX, lastY] = [e.offsetX, e.offsetY];
}

function draw(e) {
  if (!isDrawing) return;
  ctx.beginPath();
  ctx.moveTo(lastX, lastY);
  ctx.lineTo(e.offsetX, e.offsetY);
  ctx.stroke();
  [lastX, lastY] = [e.offsetX, e.offsetY];
}

function stopDrawing() {
  isDrawing = false;
}

function clearCanvas() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
}

// Text-to-Speech functionality
function playCharacterSound(character) {
  const utterance = new SpeechSynthesisUtterance(character);
  utterance.lang = 'ja-JP';
  speechSynthesis.speak(utterance);
}

function playSound(btn) {
  gsap.to(btn, {
    scale: 0.95,
    duration: 0.1,
    yoyo: true,
    repeat: 1
  });
  const utterance = new SpeechSynthesisUtterance('こんにちは');
  utterance.lang = 'ja-JP';
  speechSynthesis.speak(utterance);
}

// OCR Character Recognition
async function recognizeCharacter() {
  const canvas = document.getElementById('handwritingPad');
  const ctx = canvas.getContext('2d');
  const canvasData = ctx.getImageData(0, 0, canvas.width, canvas.height);

  // Check if the canvas is empty
  let isEmpty = true;
  for (let i = 0; i < canvasData.data.length; i += 4) {
    if (canvasData.data[i + 3] !== 0) { // Check the alpha channel
      isEmpty = false;
      break;
    }
  }

  if (isEmpty) {
    const responseBlock = document.getElementById('responseBlock');
    responseBlock.innerHTML = '<p>Please draw something on the canvas before checking!</p>';
    return;
  }

  // Get the target character
  const targetCharacter = document.getElementById('targetWord').textContent;

  // Convert canvas to a Base64 image
  const canvasImage = canvas.toDataURL('image/png');

  // Send the data to the server
  try {
    const response = await fetch('/check_character', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        targetCharacter: targetCharacter,
        handwritingImage: canvasImage,
      }),
    });

    const result = await response.json();
    const responseBlock = document.getElementById('responseBlock');
    if (response.ok) {
      responseBlock.innerHTML = `
        <p><strong>Similarity Score:</strong> ${result.similarity_score}</p>
        <p><strong>Feedback:</strong> ${result.feedback}</p>
      `;
    } else {
      responseBlock.innerHTML = `<p>Error: ${result.error}</p>`;
    }
  } catch (error) {
    console.error('Error sending data to the server:', error);
    const responseBlock = document.getElementById('responseBlock');
    responseBlock.innerHTML = '<p>An error occurred while checking your handwriting. Please try again.</p>';
  }
}

// Grammar Search (mock function)
function searchGrammarExamples() {
  // In a real implementation, this would integrate with Bing Web Search API
  alert('Searching for grammar examples using Bing Web Search API...');
}

// Add some animation on page load
gsap.from('.lesson-card', {
  y: 50,
  opacity: 0,
  duration: 1,
  stagger: 0.2,
  ease: 'power2.out'
});

</script>
{% endblock scripts %}