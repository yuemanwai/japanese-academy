{% block scripts %}
{{ super() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
// Populate Hiragana grid
const hiraganaGrid = document.getElementById('hiraganaGrid');
hiragana.forEach(char => {
  const div = document.createElement('div');
  div.className = 'glass-button';
  div.textContent = char;
  div.onclick = () => playCharacterSound(char);
  hiraganaGrid.appendChild(div);
});

// Canvas setup for handwriting
const canvas = document.getElementById('handwritingPad');
const ctx = canvas.getContext('2d');
let isDrawing = false;
let lastX = 0;
let lastY = 0;

// Set canvas dimensions to match display size
function setupCanvas() {
  const rect = canvas.getBoundingClientRect();
  const dpr = window.devicePixelRatio || 1;
  
  // Set the internal size (resolution)
  canvas.width = rect.width * dpr;
  canvas.height = rect.height * dpr;
  
  // Scale the context for high DPI displays
  ctx.scale(dpr, dpr);
  
  // Set CSS size (display size)
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
}

// Initialize canvas with white background
function initializeCanvas() {
  setupCanvas(); // Set up canvas dimensions first
  ctx.fillStyle = '#FFFFFF'; // Set background to white
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.strokeStyle = '#000000'; // Set stroke color to black
  ctx.lineJoin = 'round';
  ctx.lineCap = 'round';
  ctx.lineWidth = 8;
}

// Clear canvas and reset to white background
function clearCanvas() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  initializeCanvas();
}

canvas.addEventListener('mousedown', startDrawing);
canvas.addEventListener('mousemove', draw);
canvas.addEventListener('mouseup', stopDrawing);
canvas.addEventListener('mouseout', stopDrawing);

// Add touch support for mobile devices
canvas.addEventListener('touchstart', handleTouchStart);
canvas.addEventListener('touchmove', handleTouchMove);
canvas.addEventListener('touchend', stopDrawing);

function handleTouchStart(e) {
  e.preventDefault();
  const touch = e.touches[0];
  const rect = canvas.getBoundingClientRect();
  const x = touch.clientX - rect.left;
  const y = touch.clientY - rect.top;
  isDrawing = true;
  [lastX, lastY] = [x, y];
}

function handleTouchMove(e) {
  e.preventDefault();
  if (!isDrawing) return;
  const touch = e.touches[0];
  const rect = canvas.getBoundingClientRect();
  const x = touch.clientX - rect.left;
  const y = touch.clientY - rect.top;
  
  ctx.beginPath();
  ctx.moveTo(lastX, lastY);
  ctx.lineTo(x, y);
  ctx.stroke();
  [lastX, lastY] = [x, y];
}

// Handle window resize
window.addEventListener('resize', () => {
  setTimeout(initializeCanvas, 100);
});

function startDrawing(e) {
  isDrawing = true;
  const rect = canvas.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  [lastX, lastY] = [x, y];
}

function draw(e) {
  if (!isDrawing) return;
  const rect = canvas.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  
  ctx.beginPath();
  ctx.moveTo(lastX, lastY);
  ctx.lineTo(x, y);
  ctx.stroke();
  [lastX, lastY] = [x, y];
}

function stopDrawing() {
  isDrawing = false;
}

// Initialize canvas on page load
window.addEventListener('load', () => {
  setTimeout(initializeCanvas, 100); // Small delay to ensure canvas is rendered
});

// Text-to-Speech functionality
function playCharacterSound(character) {
  const utterance = new SpeechSynthesisUtterance(character);
  utterance.lang = 'ja-JP';
  speechSynthesis.speak(utterance);
}

// OCR Character Recognition
async function recognizeCharacter() {
  const canvas = document.getElementById('handwritingPad');
  const ctx = canvas.getContext('2d');
  const canvasData = ctx.getImageData(0, 0, canvas.width, canvas.height);

  // Check if the canvas is empty
  let isEmpty = true;
  for (let i = 0; i < canvasData.data.length; i += 4) {
    if (canvasData.data[i + 3] !== 0) { // Check the alpha channel
      isEmpty = false;
      break;
    }
  }

  if (isEmpty) {
    const responseBlock = document.getElementById('responseBlock');
    responseBlock.innerHTML = '<p>Please draw something on the canvas before checking!</p>';
    return;
  }

  // Get the target character and extract the last character
  const targetCharacter = document.getElementById('targetWord').textContent.trim();
  const lastCharacter = targetCharacter.slice(-1); // Extract the last character

  // Convert canvas to a Base64 image
  const canvasImage = canvas.toDataURL('image/png');

  // Send the data to the server
  try {
    const response = await fetch('/check_character', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        targetCharacter: lastCharacter,
        handwritingImage: canvasImage,
      }),
    });

    const result = await response.json();
    const responseBlock = document.getElementById('responseBlock');
    if (response.ok) {
      responseBlock.innerHTML = `
        <p><strong>Similarity Score:</strong> ${result.similarity_score}</p>
        <p><strong>Feedback:</strong> ${result.feedback}</p>
      `;
    } else {
      responseBlock.innerHTML = `<p>Error: ${result.error}</p>`;
    }
  } catch (error) {
    console.error('Error sending data to the server:', error);
    const responseBlock = document.getElementById('responseBlock');
    responseBlock.innerHTML = '<p>An error occurred while checking your handwriting. Please try again.</p>';
  }
}

// Grammar Search (mock function)
function searchGrammarExamples() {
  // In a real implementation, this would integrate with Bing Web Search API
  alert('Searching for grammar examples using Bing Web Search API...');
}

// Add some animation on page load
gsap.from('.lesson-card', {
  y: 50,
  opacity: 0,
  duration: 1,
  stagger: 0.2,
  ease: 'power2.out'
});

</script>
{% endblock scripts %}