{% extends "base.html.j2" %}

{% block head %}
{{ super() }}
<style>
  .score-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
  }
  .score-card {
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 2rem;
    text-align: center;
  }
  .score-card h2 {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .score-card p {
    font-size: 1.2rem;
    color: var(--dark);
  }
</style>
{% endblock head %}

{% block app_content %}
<div class="score-container">
  <div class="score-card">
    <h2>Video Evaluation Result</h2>
    <p>{{ evaluation }}</p>
  </div>
</div>
{% endblock app_content %}

{% block scripts %}
{{ super() }}
<script>
</script>
{% endblock scripts %}