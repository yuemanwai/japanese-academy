{% extends "base.html.j2" %}

{% block head %}
{{ super() }}
<style>
  .record-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
  }
  video {
    border: 2px solid #ccc;
    border-radius: 10px;
    margin-bottom: 1rem;
  }
  .btn {
    background: var(--primary);
    color: white;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 25px;
    cursor: pointer;
    transition: background 0.3s ease;
    margin: 0 0.5rem;
  }
  .btn:hover {
    background: var(--secondary);
    color: white;
  }
  .btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }
  .record-card {
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 2rem;
    text-align: center;
  }
  .record-card h2 {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .record-card p {
    font-size: 1.2rem;
    color: var(--dark);
  }
  .button-row {
    display: flex;
    justify-content: center;
    margin-top: 1rem;
  }
  .upload-container {
    margin-top: 1rem;
    display: flex;
    align-items: center;
  }
  .evaluation-results {
    text-align: left;
    margin-top: 1rem;
  }
  .evaluation-results h3 {
    font-size: 1.5rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }
  .evaluation-results p {
    font-size: 1rem;
    color: var(--dark);
  }
</style>
{% endblock head %}

{% block app_content %}
<div class="record-container">
  <div class="record-card">
    <h2>Record Your Video</h2>
    {% if evaluation %}
      <div class="evaluation-results">
        <h3>Evaluation Criteria</h3>
        {% for criterion, details in evaluation.evaluation_criteria.items() %}
          <p><strong>{{ criterion|capitalize }}:</strong> Score: {{ details.score }}</p>
        {% endfor %}
        <h3>Summary</h3>
        <p><strong>Passing Probability:</strong></p>
        <ul>
          {% for level, probability in evaluation.summary.passing_probability.items() %}
            <li>{{ level }}: {{ probability }}</li>
          {% endfor %}
        </ul>
        <p><strong>Recommendations:</strong> {{ evaluation.summary.feedback_and_recommendations }}</p>
      </div>
    {% else %}
      <p>Record your video and get an evaluation.</p>
      <video id="video" width="640" height="480" autoplay></video>
      <div class="button-row">
        <button id="startBtn" class="btn">Start Recording</button>
        <button id="stopBtn" class="btn" disabled>Stop Recording</button>
        <button id="evaluateBtn" class="btn" disabled>Evaluate Video</button>
      </div>
      <div class="upload-container">
        <input type="file" id="uploadInput" accept="video/*">
        <button id="evaluateUploadBtn" class="btn" disabled>Evaluate Upload Video</button>
      </div>
    {% endif %}
  </div>
</div>
{% endblock app_content %}

{% block scripts %}
{{ super() }}
<script>
  const video = document.getElementById('video');
  const startBtn = document.getElementById('startBtn');
  const stopBtn = document.getElementById('stopBtn');
  const evaluateBtn = document.getElementById('evaluateBtn');
  const evaluateUploadBtn = document.getElementById('evaluateUploadBtn');
  const uploadInput = document.getElementById('uploadInput');
  let mediaRecorder;
  let recordedChunks = [];

  navigator.mediaDevices.getUserMedia({ video: true })
    .then(stream => {
      video.srcObject = stream;
      mediaRecorder = new MediaRecorder(stream);

      mediaRecorder.ondataavailable = function(event) {
        if (event.data.size > 0) {
          recordedChunks.push(event.data);
        }
      };

      mediaRecorder.onstop = function() {
        const blob = new Blob(recordedChunks, { type: 'video/webm' });
        const formData = new FormData();
        formData.append('video', blob, 'recorded_video.webm');

        fetch('/video_evaluation', {
          method: 'POST',
          body: formData
        }).catch(error => {
          console.error('Error uploading recorded video:', error);
        });
      };
    })
    .catch(error => {
      console.error('Error accessing media devices.', error);
    });

  startBtn.addEventListener('click', () => {
    recordedChunks = [];
    mediaRecorder.start();
    startBtn.disabled = true;
    stopBtn.disabled = false;
    evaluateBtn.disabled = true;
  });

  stopBtn.addEventListener('click', () => {
    mediaRecorder.stop();
    startBtn.disabled = false;
    stopBtn.disabled = true;
    evaluateBtn.disabled = false;
  });

  evaluateBtn.addEventListener('click', () => {
    const blob = new Blob(recordedChunks, { type: 'video/webm' });
    const formData = new FormData();
    formData.append('video', blob, 'recorded_video.webm');

    fetch('/video_evaluation', {
      method: 'POST',
      body: formData
    }).catch(error => {
      console.error('Error sending evaluation request:', error);
      alert('Error sending evaluation request: ' + error.message);
    });
  });

  uploadInput.addEventListener('change', () => {
    console.log('File input changed');
    evaluateUploadBtn.disabled = uploadInput.files.length === 0;
  });

  evaluateUploadBtn.addEventListener('click', () => {
    const file = uploadInput.files[0];
    const formData = new FormData();
    formData.append('video', file);

    fetch('/video_evaluation', {
      method: 'POST',
      body: formData
    }).catch(error => {
      console.error('Error uploading video:', error);
      alert('Error uploading video: ' + error.message);
    });
  });

</script>
{% endblock scripts %}
