{% extends 'bootstrap/base.html' %}

{% block head %}
{{super()}}
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ url_for('static', filename='css/modern-style.css') }}">

{% endblock head %}

{% block title %} {{ site_name }} {% endblock title %}

{% block navbar %}
<header>
  <div class="container">
    <h1><a href="{{ url_for('index') }}">{{ site_name }}</a></h1>
    <nav>
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse"
        data-target="#bs-example-navbar-collapse-1" aria-expanded="false">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <ul class="navbar-nav collapse navbar-collapse" id="bs-example-navbar-collapse-1">
        <li><a href="{{ url_for('index') }}" class="{% if request.endpoint == 'index' %}active{% endif %}">{{_('Home')}}</a></li>
        <li><a href="{{ url_for('lessons') }}" class="{% if request.endpoint == 'lessons' %}active{% endif %}">{{ _('Lessons') }}</a></li>
        <li><a href="{{ url_for('practice') }}" class="{% if request.endpoint == 'practice' %}active{% endif %}">{{ _('Practice') }}</a></li>
        {% if current_user.is_anonymous %}
        <li><a href="{{ url_for('register') }}" class="{% if request.endpoint == 'register' %}active{% endif %}">{{ _('Sign up') }}</a></li>
        <li><a href="{{ url_for('login') }}" class="{% if request.endpoint == 'login' %}active{% endif %}">{{ _('Sign in') }}</a></li>
        {% else %}
        <li><a href="{{ url_for('user', username=current_user.username) }}" class="{% if request.endpoint == 'user' %}active{% endif %}">{{_('Profile')}}</a></li>
        <li><a href="{{ url_for('logout') }}" class="{% if request.endpoint == 'logout' %}active{% endif %}">{{_('Sign out')}}</a></li>
        {% endif %}
        <li class="language-dropdown">
          <a href="#" class="dropdown-toggle">{{_('Language')}} ▼</a>
          <div class="dropdown-menu">
            <form method="post" action="{{ url_for('set_language') }}">
              <input type="hidden" name="language" value="en">
              <button type="submit" class="dropdown-item">English</button>
            </form>
            <form method="post" action="{{ url_for('set_language') }}">
              <input type="hidden" name="language" value="zh">
              <button type="submit" class="dropdown-item">中文</button>
            </form>
            <form method="post" action="{{ url_for('set_language') }}">
              <input type="hidden" name="language" value="ja">
              <button type="submit" class="dropdown-item">日本語</button>
            </form>
          </div>
        </li>
        <li>
          <div class="theme-switch-wrapper">
            <label class="theme-switch" for="theme-toggle">
              <input type="checkbox" id="theme-toggle" />
              <span class="slider">
                <span class="slider-icon sun"><img src="{{ url_for('static', filename='image/icon-sun.png') }}" alt="Light Mode"></span>
                <span class="slider-icon moon"><img src="{{ url_for('static', filename='image/icon-moon.png') }}" alt="Dark Mode"></span>
              </span>
            </label>
          </div>
        </li>
      </ul>
      
      {# Search form moved to a separate section or removed #}
      <div class="search-section" style="display: none;">
        <form class="d-flex" action="{{ url_for('search') }}" method="post">
          {{ g.search_form.hidden_tag() }}
          {{ g.search_form.keyword(class="form-control", placeholder=_('Search...'), aria_label="Search") }}
          <button type="submit" class="btn btn-outline-success">{{ _('Search') }}</button>
        </form>
      </div>
    </nav>
  </div>
</header>
{% endblock navbar %}

{% block content %}
<div class="container-fluid">
  <div class="col-md-12">
    {% with messages = get_flashed_messages() %}
    {% if messages %}
    {% for message in messages %}
    <div class="alert alert-info" role="alert">{{ message }}</div>
    {% endfor %}
    {% endif %}
    {% endwith %}
    {% block app_content %} {% endblock app_content %}
  </div>
</div>

{% block footer %}
<footer class="footer">
  {# Placeholder #}
  <a href="{{ url_for('leave_message') }}">{{ _('Contact Support') }}</a>
  <a href="{{ url_for('get_random_post') }}">{{ _('Random post') }}</a>
  <a href="{{ url_for('donate') }}">{{_('Donate') }}</a>
  <a href="{{ url_for('chat_with_copilot') }}">{{ _('Chat with Copilot') }}</a>
  {% if current_user.is_authenticated and current_user.is_admin %}
  <a href="/404">{{ _('404 Quick button') }}</a>
  {% endif %}
</footer>
{% endblock footer %}
{% endblock content %}

{% block scripts %}
{{ super() }}
{{ moment.include_moment() }}
{{ moment.lang(g.locale) }}
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"
  integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl"
  crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"
  integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN"
  crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"
  integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q"
  crossorigin="anonymous"></script>
<script defer src="https://use.fontawesome.com/releases/v6.5.0/js/all.js"></script>
<script src="{{ url_for('static', filename='js/modern-theme.js') }}"></script>
<script>
  // Hide flash messages after 5 seconds
  setTimeout(() => {
    const alerts = document.querySelectorAll('.alert');
    alerts.forEach(alert => {
      alert.style.opacity = '0';
    });
  }, 5000);
</script>
{% endblock scripts %}

