{% extends 'bootstrap/base.html' %}

{% block head %}
{{super()}}
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="bootstrap/css/bootstrap.min.css">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=FZShuTi:wght@400&display=swap" rel="stylesheet">
<style>
  * {
    font-family: 'FZShuTi', sans-serif;
    font-size: 19px;
    color: whitesmoke;
  }

  body {
    background-color: black;
  }

  .navbar-brand {
    font-size: 27px;
    font-weight: bold;
  }

  .footer {
    position: fixed;
    bottom: 0;
    width: 100%;
    background-color: black;
    text-align: center;
  }

  .footer a {
    margin: 0 10px;
    font-size: smaller;
  }

  .footer a:hover {
    margin: 0 10px;
    font-size: smaller;
    color: whitesmoke;
  }

  .navbar-nav .nav-link {
    padding: 10px;
    margin: 8px;
    text-decoration: none;
  }

  .navbar-nav .nav-item.active .nav-link {
    background-color: black;
    color: whitesmoke !important;
    font-weight: bold;
    border-bottom: 2px solid whitesmoke;
  }

  .navbar-nav .nav-item {
    margin-top: 8px;
    margin-right: 10px;
  }

  #submit {
    font-size: 18px;
    font-weight: bold;
    width: 200px;
    background-color: #ff6b6b;
    color: black;
    border: 1px solid #ff6b6b;
    margin-top: 15px;
  }

  .form-control {
    margin-top: 4px;
    background-color: black;
    border: 1px solid whitesmoke;
    color: whitesmoke;
  }

  .search-icon {
    margin-top: 4px;
  }

  .alert {
    background-color: black;
    border: 1px solid whitesmoke;
  }

  a {
    color: whitesmoke;
  }

  .nav-item a:hover {
    color: whitesmoke;
    border-bottom: 2px solid whitesmoke;
  }
</style>
{% endblock head %}

{% block title %} {{ site_name }} {% endblock title %}

{% block navbar %}
<div class="container-fluid">
  <nav class="navbar navbar-dark navbar-fullwidth" style="padding: 0 30px;">
    {# Fixed Elements #}
    <div class="navbar-header">
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse"
        data-target="#bs-example-navbar-collapse-1" aria-expanded="false">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <span class="navbar-brand">{{ site_name }}</span>
    </div>

    {# Left Side of Navbar #}
    <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
      <ul class="nav navbar-nav">
        <li>
          <form class="d-flex" action="{{ url_for('search') }}" role="search"
            style="display: inline-flex;width: 350px;padding: 8px 0px;">
            <span class="search-icon">
              <i class="fa-solid fa-magnifying-glass"
                style="font-size: 20px;margin-top:8px; margin-right:8px;  color: writesmoke;"></i>
            </span>
            <input class="form-control" type="search" placeholder="{{ _('Search...') }}" aria-label="Search">
          </form>
        </li>
      </ul>

      {# Right Side of Navbar #}
      <ul class="nav navbar-nav navbar-right">
        <div style="display: flex; margin-top: 8px; align-items: center;">
          <li class="nav-item {% if request.endpoint == 'index' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('index') }}">{{_('Home')}} <span class="sr-only">(current)</span></a>
          </li>
          <li class="nav-item {% if request.endpoint == 'lessons' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('lessons') }}">{{ _('Lessons') }}</a>
          </li>
          <li class="nav-item {% if request.endpoint == 'practice' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('practice') }}">{{ _('Practice') }}</a>
          </li>
          <li class="nav-item {% if request.endpoint == 'dictionary' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('dictionary') }}">{{ _('Dictionary') }}</a>
          </li>
          <li class="nav-item {% if request.endpoint == 'community' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('community') }}">{{ _('Community') }}</a>
          </li>
          {% if current_user.is_anonymous %}
          <li class="nav-item {% if request.endpoint == 'register' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('register') }}">{{ _('Sign up') }}</a>
          </li>
          <li class="nav-item {% if request.endpoint == 'login' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('login') }}">{{ _('Sign in') }}</a>
          </li>

          {% else %}

          <li class="nav-item {% if request.endpoint == 'user' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('user', username=current_user.username) }}">
              {{_('Profile')}}
            </a>
          </li>
          {# <li class="nav-item {% if request.endpoint == 'watchlist' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('watchlist', username=current_user.username) }}">
              <i class="fa-regular fa-star" style="font-size: 20px; "></i>
            </a>
          </li> #}
          <li class="nav-item {% if request.endpoint == 'logout' %}active{% endif %}">
            <a class="nav-link" href="{{ url_for('logout') }}">
              {{_('Sign out')}}
            </a>
          </li>
        </div>

        {% endif %}

      </ul>
  </nav>
  {% endblock navbar %}

  {% block content %}
  <div class="container-fluid">
    <div class="col-md-12">
      {% with messages = get_flashed_messages() %}
      {% if messages %}
      {% for message in messages %}
      <div class="alert alert-info" role="alert">{{ message }}</div>
      {% endfor %}
      {% endif %}
      {% endwith %}
      {% block app_content %} {% endblock app_content %}
      <div style="position: fixed; bottom: 20px; right: 20px;">
        <a href="{{ url_for('chat_with_copilot') }}">
          <img src="../static/image/ai_icon.png" alt="Icon" style="width: 100px; height: 100px;">
        </a>
      </div>
    </div>
  </div>

  {% block footer %}
  <footer class="footer">
    {# Placeholder #}
    <a href="{{ url_for('leave_message') }}">{{ _('Contact Support') }}</a>
    <a href="{{ url_for('get_random_post') }}">{{ _('Random post') }}</a>
    <a href="{{ url_for('donate') }}">{{_('Donate') }}</a>
    <a href="{{ url_for('chat_with_copilot') }}">{{ _('Chat with Copilot') }}</a>
    {% if current_user.is_authenticated and current_user.is_admin %}
    <a href="/404">{{ _('404 Quick button') }}</a>
    {% endif %}
  </footer>
  {% endblock footer %}
  {% endblock content %}


  {% block scripts %}
  {{ super() }}
  {{ moment.include_moment() }}
  {{ moment.lang(g.locale) }}
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"
    integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl"
    crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"
    integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN"
    crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js"
    integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q"
    crossorigin="anonymous"></script>
  <script defer src="https://use.fontawesome.com/releases/v6.5.0/js/all.js"></script>

  {% endblock scripts %}