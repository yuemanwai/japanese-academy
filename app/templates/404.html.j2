{% extends "bootstrap/base.html" %}

{% block title %} 404 - Page Not Found | AI-Powered Japanese Learning Platform {% endblock %}

{% block head %}
{{super()}}
<meta charset="UTF-8">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<style>
:root {
  --primary: #ff6b6b;
  --secondary: #4ecdc4;
  --dark: #2c3e50;
  --light: #f7f9fc;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Noto Sans JP', sans-serif;
}

body {
  background: var(--light);
  color: var(--dark);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.error-container {
  text-align: center;
  padding: 2rem;
}

.error-code {
  font-size: 120px;
  color: var(--primary);
  font-weight: bold;
  text-shadow: 2px 2px 0 var(--secondary);
  margin-bottom: 1rem;
}

.error-message {
  font-size: 24px;
  margin-bottom: 2rem;
}

.japanese-error {
  font-size: 28px;
  color: var(--dark);
  margin-bottom: 2rem;
}

.error-illustration {
  width: 300px;
  height: 300px;
  margin: 2rem auto;
}

.btn-home {
  background: var(--primary);
  color: white;
  border: none;
  padding: 1rem 2rem;
  border-radius: 25px;
  text-decoration: none;
  font-size: 18px;
  transition: all 0.3s ease;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-home:hover {
  background: var(--secondary);
  transform: translateY(-2px);
}

.kanji-animation {
  position: fixed;
  pointer-events: none;
  z-index: -1;
  opacity: 0.1;
}

</style>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
{% endblock %}

{% block content %}

<div class="error-container">
  <div class="error-code">404</div>
  <div class="japanese-error">ページが見つかりません</div>
  <div class="error-message">Oops! Looks like this page got lost in translation!</div>
  
  <svg class="error-illustration" viewBox="0 0 200 200">
    <defs>
      <radialGradient id="bgGradient" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
        <stop offset="0%" style="stop-color:var(--secondary);stop-opacity:0.3"/>
        <stop offset="100%" style="stop-color:var(--primary);stop-opacity:0.1"/>
      </radialGradient>
    </defs>
    <circle cx="100" cy="100" r="90" fill="url(#bgGradient)"/>
    <path id="sadFace" d="M65,120 Q100,90 135,120" stroke="var(--dark)" fill="none" stroke-width="5"/>
    <circle cx="75" cy="80" r="8" fill="var(--dark)"/>
    <circle cx="125" cy="80" r="8" fill="var(--dark)"/>
  </svg>
  
  <a href="{{ url_for('index') }}" class="btn-home">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
    </svg>
    Return Home
  </a>
</div>

<p>
    <a href="{{ url_for('index') }}">{{ _('Back to Home') }}</a>
</p>

{% endblock %}

{% block scripts %}
{{super()}}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
// Create floating kanji background
const kanji = ['学', '習', '日', '本', '語', '愛'];
const container = document.body;

for (let i = 0; i < 20; i++) {
  const kanjiEl = document.createElement('div');
  kanjiEl.className = 'kanji-animation';
  kanjiEl.textContent = kanji[Math.floor(Math.random() * kanji.length)];
  kanjiEl.style.left = `${Math.random() * 100}vw`;
  kanjiEl.style.top = `${Math.random() * 100}vh`;
  kanjiEl.style.fontSize = `${Math.random() * 40 + 20}px`;
  container.appendChild(kanjiEl);
}

// Animations
gsap.from('.error-code', {
  y: -100,
  opacity: 0,
  duration: 1,
  ease: 'bounce.out'
});

gsap.from('.japanese-error', {
  y: 50,
  opacity: 0,
  duration: 0.8,
  delay: 0.3
});

gsap.from('.error-message', {
  y: 50,
  opacity: 0,
  duration: 0.8,
  delay: 0.6
});

gsap.from('.error-illustration', {
  scale: 0,
  opacity: 0,
  duration: 1,
  delay: 0.9,
  ease: 'elastic.out(1, 0.5)'
});

gsap.from('.btn-home', {
  y: 30,
  opacity: 0,
  duration: 0.8,
  delay: 1.2
});

// Animate floating kanji
document.querySelectorAll('.kanji-animation').forEach(kanji => {
  gsap.to(kanji, {
    y: `-=${Math.random() * 100 + 50}`,
    x: `+=${Math.random() * 50 - 25}`,
    rotation: Math.random() * 360,
    duration: Math.random() * 5 + 5,
    repeat: -1,
    yoyo: true,
    ease: 'none'
  });
});

// Animate sad face
gsap.to('#sadFace', {
  attr: {
    d: 'M65,120 Q100,100 135,120'
  },
  duration: 2,
  repeat: -1,
  yoyo: true,
  ease: 'power1.inOut'
});

</script>
{% endblock %}