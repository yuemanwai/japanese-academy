<html>

<head>
  <meta charset="UTF-8">
  <title>AI-Powered Japanese Learning Platform</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@3.11.0/dist/tf.min.js"></script>
  <style>

    :root {
      --primary: #ff6b6b;
      --secondary: #4ecdc4;
      --dark: #2c3e50;
      --light: #f7f9fc;
      --accent: #ffd93d;
    }

    .hero-section {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #2c3e50, #3498db);
    }

    .ai-character {
      position: relative;
      width: 400px;
      height: 500px;
      margin-right: 2rem;
    }

    .character-container {
      position: relative;
      width: 100%;
      height: 100%;
    }

    .character-svg {
      width: 100%;
      height: 100%;
      position: absolute;
      top: 0;
      left: 0;
    }

    .speech-bubble {
      position: absolute;
      top: -80px;
      right: -20px;
      background: white;
      padding: 1rem;
      border-radius: 15px;
      max-width: 250px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      opacity: 0;
      transform: translateY(20px);
    }

    .speech-bubble:after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 50%;
      border-width: 10px 10px 0;
      border-style: solid;
      border-color: white transparent;
    }

    .welcome-content {
      max-width: 500px;
      color: white;
      padding: 2rem;
    }

    .welcome-content h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
      font-weight: 700;
    }

    .welcome-content p {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      opacity: 0.9;
    }

    .cta-buttons {
      display: flex;
      gap: 1rem;
    }

    .cta-primary {
      background: var(--accent);
      color: var(--dark);
      padding: 1rem 2rem;
      border-radius: 25px;
      text-decoration: none;
      font-weight: bold;
      transition: transform 0.3s ease;
    }

    .cta-primary:hover {
      transform: translateY(-2px);
    }

    .cta-secondary {
      background: transparent;
      border: 2px solid white;
      color: white;
      padding: 1rem 2rem;
      border-radius: 25px;
      text-decoration: none;
      font-weight: bold;
      transition: transform 0.3s ease;
    }

    .cta-secondary:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.1);
    }

    .interactive-elements {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .floating-hiragana {
      position: absolute;
      font-size: 2rem;
      color: rgba(255, 255, 255, 0.2);
      pointer-events: none;
      user-select: none;
    }

    /* Add animation keyframes */
    @keyframes float {
      0% {
        transform: translateY(0px);
      }

      50% {
        transform: translateY(-20px);
      }

      100% {
        transform: translateY(0px);
      }
    }

    @keyframes pulse {
      0% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.05);
      }

      100% {
        transform: scale(1);
      }
    }
  </style>
</head>

<body>

  <!-- Header remains the same -->
  <header>
    <!-- ... Previous header content ... -->
  </header>

  <!-- New Hero Section -->
  <section class="hero-section">
    <div class="interactive-elements" id="floatingCharacters"></div>

    <div class="ai-character">
      <div class="character-container" id="aiCharacter">
        <svg class="character-svg" viewBox="0 0 200 300">
          <!-- Basic anime character SVG -->
          <g id="character">
            {# <!-- Head -->
            <circle cx="100" cy="80" r="40" fill="#FFE0BD" />
            <!-- Eyes -->
            <ellipse cx="85" cy="70" rx="5" ry="8" fill="#2C3E50" />
            <ellipse cx="115" cy="70" rx="5" ry="8" fill="#2C3E50" />
            <!-- Mouth -->
            <path d="M90 95 Q100 105 110 95" stroke="#2C3E50" fill="none" stroke-width="2" />
            <!-- Body -->
            <path d="M80 120 L120 120 L130 250 L70 250 Z" fill="#FF6B6B" /> #}
            <!-- PNG Image -->
            <image href="../static/teacher.png" x="0" y="70" width="200" height="150" />
          </g>
        </svg>
        <div class="speech-bubble" id="speechBubble">
          こんにちは! Ready to learn Japanese?
        </div>
      </div>
    </div>

    <div class="welcome-content">
      <h1>Learn Japanese with AI</h1>
      <p>Join our interactive learning platform featuring an AI tutor who adapts to your learning style. Master
        Hiragana, Katakana, and basic conversations through engaging lessons.</p>
      <div class="cta-buttons">
        <a href="/get-started" class="cta-primary">Start Learning Now</a>
        <a href="/how-it-works" class="cta-secondary">How It Works</a>
      </div>
    </div>
  </section>

  <script>
    // Create floating Hiragana characters
    const hiraganaChars = 'あいうえおかきくけこさしすせそたちつてと';
    const floatingElements = document.getElementById('floatingCharacters');

    function createFloatingChar() {
      const char = document.createElement('div');
      char.className = 'floating-hiragana';
      char.textContent = hiraganaChars[Math.floor(Math.random() * hiraganaChars.length)];
      char.style.left = Math.random() * 100 + 'vw';
      char.style.top = Math.random() * 100 + 'vh';
      char.style.animation = `float ${3 + Math.random() * 4}s infinite`;
      floatingElements.appendChild(char);

      // Remove after animation
      setTimeout(() => {
        char.remove();
      }, 7000);
    }

    // Create floating characters periodically
    setInterval(createFloatingChar, 1000);

    // Animate AI character
    const character = document.getElementById('character');
    const speechBubble = document.getElementById('speechBubble');

    // Basic animation for the character
    gsap.to(character, {
      y: 10,
      duration: 2,
      repeat: -1,
      yoyo: true,
      ease: "power1.inOut"
    });

    // Speech bubble animation
    gsap.to(speechBubble, {
      opacity: 1,
      y: 80,
      duration: 0.5,
      delay: 1
    });

    // Interactive character responses
    const characterResponses = [
      "がんばって! (Do your best!)",
      "すごい! (Amazing!)",
      "よくできました! (Well done!)",
      "一緒に勉強しましょう! (Let's study together!)",
      "ヤハ（呀哈）",
      "ウラ（嗚啦）",
      "ウラヤハウラヤハ！（嗚啦呀哈嗚啦呀哈！)"
    ];

    document.querySelector('.ai-character').addEventListener('click', () => {
      const response = characterResponses[Math.floor(Math.random() * characterResponses.length)];
      speechBubble.textContent = response;

      gsap.from(speechBubble, {
        scale: 0.8,
        duration: 0.3,
        ease: "back.out"
      });
    });

    // Mouse interaction with character
    document.addEventListener('mousemove', (e) => {
      const characterRect = character.getBoundingClientRect();
      const characterCenterX = characterRect.left + characterRect.width / 2;
      const characterCenterY = characterRect.top + characterRect.height / 2;

      const angleX = (e.clientX - characterCenterX) * 0.01;
      const angleY = (e.clientY - characterCenterY) * 0.01;

      gsap.to(character, {
        rotationY: angleX,
        rotationX: -angleY,
        duration: 0.5
      });
    });

    // Add some particle effects when clicking the CTA buttons
    document.querySelector('.cta-primary').addEventListener('click', (e) => {
      createParticleEffect(e.clientX, e.clientY);
    });

    function createParticleEffect(x, y) {
      for (let i = 0; i < 10; i++) {
        const particle = document.createElement('div');
        particle.style.position = 'absolute';
        particle.style.left = x + 'px';
        particle.style.top = y + 'px';
        particle.style.width = '10px';
        particle.style.height = '10px';
        particle.style.background = '#ffd93d';
        particle.style.borderRadius = '50%';
        document.body.appendChild(particle);

        gsap.to(particle, {
          x: (Math.random() - 0.5) * 100,
          y: (Math.random() - 0.5) * 100,
          opacity: 0,
          duration: 1,
          onComplete: () => particle.remove()
        });
      }
    }

    // Add smooth scroll for navigation
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute('href')).scrollIntoView({
          behavior: 'smooth'
        });
      });
    });

  </script>

</body>

</html>