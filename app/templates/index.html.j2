{% extends "base.html.j2" %}

{% block head %}
{{ super() }}
<style>
/* Feature card styles */
.features {
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 每行顯示3個 */
  gap: 2rem;
  padding: 4rem 2rem;
}

.feature-card img {
  max-width: 100%;
  max-height: 70%;
  border-radius: 15px;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.feature-card {
  margin: 20px;
  height: 400px;
  background-image: radial-gradient(circle, #80f9bd, #4cf3e7, #53e9ff, #86daff, #b4cbff, #cec3f8, #e4bbea, #f4b5d7, #fab5c9, #fcb7bd, #f9bbb3, #f4bfab);
  padding: 2rem;
  border-radius: 10px;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  transition: transform 0.3s;
  color: var(--dark); /* 設置字體顏色為深色 */
  text-align: center; /* 置中文字 */
}
.feature-card p {
  color: var(--dark); /* 設置字體顏色為深色 */
}

.feature-card:hover {
  transform: translateY(-5px);
  background-image: linear-gradient(to right top, #d16ba5, #c777b9, #ba83ca, #aa8fd8, #9a9ae1, #8aa7ec, #79b3f4, #69bff8, #52cffe, #41dfff, #46eefa, #5ffbf1);  color: white; /* 改變字體顏色 */
  color: var(--light);
}

.centered-title {
  text-align: center; /* 置中標題 */
  width: 100%; /* 佔全行 */
}

a.feature-card:hover {
  text-decoration: none; /* 移除底線 */
}

@media (max-width: 900px) {
  .features {
    grid-template-columns: repeat(2, 1fr); /* 每行顯示2個 */
  }
}

@media (max-width: 600px) {
  .features {
    grid-template-columns: 1fr; /* 每行顯示1個 */
  }
}

</style>
{% endblock head %}

