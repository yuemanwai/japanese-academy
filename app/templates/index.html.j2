{% extends "base.html.j2" %}

{% block head %}
{{ super() }}
<style>
/* Feature card styles */
.panel {
  background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2)), url('https://images.unsplash.com/photo-1490806843957-31f4c9a91c65') center/cover fixed;
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 每行顯示3個 */
  gap: 2rem;
  padding: 4rem 2rem;
}

.glass-panel img {
  max-width: 100%;
  max-height: 70%;
  border-radius: 15px;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.glass-panel {
  margin: 20px;
  height: 400px;
  padding: 2rem;
}

.centered-title {
  text-align: center; /* 置中標題 */
  width: 100%; /* 佔全行 */
}


@media (max-width: 900px) {
  .panel {
    grid-template-columns: repeat(2, 1fr); /* 每行顯示2個 */
  }
}

@media (max-width: 600px) {
  .panel {
    grid-template-columns: 1fr; /* 每行顯示1個 */
  }
}

</style>
{% endblock head %}

{% block app_content %}
<!-- Panel -->
<div class="centered-title"><h1>{{_('Master Japanese with AI')}}</h1></div>

<section class="panel">
  <a href="{{ url_for('chat_with_copilot') }}" class="glass-panel">
    <img src="../static/image/copilot.png" alt="Image not found">
    <h3>{{ _('AI Conversation Practice') }}</h3>
    <p>{{ _('Practice speaking Japanese with Copilot anytime, anywhere') }}</p>
  </a>

  <a href="{{ url_for('lessons') }}#lesson1" class="glass-panel">
    <img src="../static/image/a.png" alt="Image not found">
    <h3>{{ _('Smart Learning Path') }}</h3>
    <p>{{ _('Personalized curriculum that adapts to your learning style and progress') }}</p>
  </a>
  
  <a href="{{ url_for('lessons') }}#lesson2" class="glass-panel">
    <img src="../static/image/jp.jpeg" alt="Image not found">
    <h3>{{ _('Real-time Feedback') }}</h3>
    <p>{{ _('Get instant corrections and suggestions to improve your Japanese skills') }}</p>
  </a>

  <a href="{{ url_for('record') }}" class="glass-panel">
    <img src="../static/image/video_icon.png" alt="Image not found">
    <h3>{{ _('Video evaluation') }}</h3>
    <p>{{ _('Japanese Video Evaluation Powered by Gemini') }}</p>
  </a>
  
</section>
{% endblock app_content %}

{% block scripts %}
{{ super() }}
{% endblock scripts %}