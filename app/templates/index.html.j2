{% extends "base.html.j2" %}

{% block head %}
{{ super() }}
{% endblock head %}

{% block app_content %}
<!-- Hero Section -->
<section id="hero">
  <div class="container">
    <h2>{{_('Transform Your Japanese Learning with AI')}}</h2>
    <p>{{_('JP Academy uses cutting-edge AI to create a personalized learning path just for you, making your journey to fluency more efficient and engaging.')}}</p>
    <a href="{{ url_for('lessons') }}" class="btn btn-primary">{{_('Start Learning')}}</a>
  </div>
</section>

<!-- AI Features Section -->
<section class="container">
  <div class="centered-title">
    <h1 class="section-title">{{_('Your Personal AI Japanese Tutor')}}</h1>
  </div>

  <div class="panel">
    <a href="{{ url_for('chat_with_copilot') }}" class="glass-panel animated-card">
      <img src="{{ url_for('static', filename='image/icon-conversation.png') }}" alt="AI Conversation">
      <h3>{{ _('Interactive Speaking Practice') }}</h3>
      <p>{{ _('Practice real conversations with our AI and get instant feedback on your pronunciation and grammar. Build confidence to speak Japanese naturally.') }}</p>
    </a>

    <a href="{{ url_for('lessons') }}#lesson1" class="glass-panel animated-card">
      <img src="{{ url_for('static', filename='image/icon-personalized.png') }}" alt="Personalized Learning">
      <h3>{{ _('Personalized Learning Path') }}</h3>
      <p>{{ _('Our AI analyzes your progress and adapts lessons to your strengths and weaknesses, so you can focus on what matters most.') }}</p>
    </a>
    
    <a href="{{ url_for('lessons') }}#lesson2" class="glass-panel animated-card">
      <img src="{{ url_for('static', filename='image/icon-flashcards.png') }}" alt="Smart Flashcards">
      <h3>{{ _('Smart Flashcard System') }}</h3>
      <p>{{ _('Master vocabulary and kanji faster with our AI-powered spaced repetition system that optimizes your study sessions.') }}</p>
    </a>

    <a href="{{ url_for('record') }}" class="glass-panel animated-card">
      <img src="{{ url_for('static', filename='image/video_icon.png') }}" alt="Video Evaluation">
      <h3>{{ _('Video Evaluation') }}</h3>
      <p>{{ _('Get your Japanese video evaluated by Gemini AI') }}</p>
    </a>
  </div>
</section>

<!-- Learning Paths Section -->
<section class="container">
  <h2 class="section-title">{{_('Explore What We Offer')}}</h2>
  <div class="learning-paths-grid">
    <div class="path-card animated-card">
      <div class="path-icon">📚</div>
      <h3>{{_('Interactive Lessons')}}</h3>
      <p>{{_('Master Japanese step by step, from basic Hiragana to advanced grammar. Our structured courses cover everything: Hiragana, Katakana, Kanji, and practical grammar.')}}</p>
      <a href="{{ url_for('lessons') }}" class="btn btn-secondary">{{_('Start Lessons')}}</a>
    </div>
    <div class="path-card animated-card">
      <div class="path-icon">💪</div>
      <h3>{{_('Practice Center')}}</h3>
      <p>{{_('Sharpen your skills with diverse exercises covering listening, reading, writing, and speaking. Practice makes perfect!')}}</p>
      <a href="{{ url_for('practice') }}" class="btn btn-secondary">{{_('Start Practicing')}}</a>
    </div>
    <div class="path-card animated-card">
      <div class="path-icon">🎯</div>
      <h3>{{_('AI Conversation Practice')}}</h3>
      <p>{{_('Chat with our AI tutor in real-time to boost your speaking and listening skills. Get instant feedback to sound more natural and fluent.')}}</p>
      <a href="{{ url_for('chat_with_copilot') }}" class="btn btn-secondary">{{_('Start Chatting')}}</a>
    </div>
    <div class="path-card animated-card">
      <div class="path-icon">📊</div>
      <h3>{{_('Progress Tracking')}}</h3>
      <p>{{_('Monitor your learning journey with detailed stats and performance insights. See what you\'re good at and where to improve.')}}</p>
      <a href="{{ url_for('user', username=current_user.username if current_user.is_authenticated else 'guest') }}" class="btn btn-secondary">{{_('View Stats')}}</a>
    </div>
  </div>
</section>
{% endblock app_content %}

{% block scripts %}
{{ super() }}
{% endblock scripts %}