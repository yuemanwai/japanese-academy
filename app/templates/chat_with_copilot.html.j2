{% extends 'base.html.j2' %}

{% block app_content %}
<div class="chat-container">
  <div class="section-title">
    <h1>{{ _('Chat with Copilot') }}</h1>
  </div>
  
  <div class="chat-content">
    <div class="control-panel glass-panel">
      <h3>{{ _('Settings') }}</h3>
      <form id="control-form" method="post" action="{{ url_for('chat_with_copilot') }}">
        {% if current_user.is_authenticated and current_user.is_admin %}
        <div class="form-group">
          <label for="debug">{{ _('Debug') }}</label>
          <input type="checkbox" id="debug" name="debug" {% if chat_settings and chat_settings.debug %}checked{% endif %}>
        </div>
        {% endif %}
        
        <div class="form-group">
          <label for="word-limit">{{ _('Word Limit') }}</label>
          <input type="number" id="word-limit" name="word-limit" value="{{ chat_settings.word_limit if chat_settings else '50' }}" min="10" class="form-control">
        </div>
        
        <div class="form-group">
          <label for="condition">{{ _('Condition') }}</label>
          <textarea id="condition" name="condition" rows="6" class="form-control">{{ chat_settings.condition if chat_settings else '' }}</textarea>
        </div>
        
        <button type="submit" class="btn btn-primary">{{ _('Apply') }}</button>
      </form>
    </div>
    
    <div class="chat-box-container glass-panel">
      <div id="chat-box" class="chat-messages">
        <!-- Chat messages will be displayed here -->
      </div>
      <form id="chat-form" method="post" class="chat-input-form">
        <div class="chat-input-group">
          <input type="text" id="user-input" name="message" placeholder="{{ _('Type your message here...') }}" required class="chat-input">
          <button type="submit" class="btn btn-primary chat-send-btn">
            <i class="fa fa-paper-plane"></i>
            {{ _('Send') }}
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .chat-container {
    padding: 2rem 0;
    max-width: 1400px;
    margin: 0 auto;
  }

  .chat-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    margin: 2rem 0;
    min-height: 70vh;
  }

  .control-panel {
    padding: 2rem;
    height: fit-content;
  }

  .control-panel h3 {
    color: var(--accent-blue);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  .form-control {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    border: 2px solid var(--accent-blue);
    border-radius: 6px;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    transition: border-color 0.3s ease;
  }

  .form-control:focus {
    outline: none;
    border-color: var(--accent-pink);
    box-shadow: 0 0 0 0.2rem rgba(255, 0, 110, 0.25);
  }

  input[type="checkbox"] {
    width: auto;
    margin-right: 0.5rem;
  }

  .chat-box-container {
    padding: 0;
    display: flex;
    flex-direction: column;
    height: 70vh;
  }

  .chat-messages {
    flex: 1;
    padding: 1.5rem;
    overflow-y: auto;
    border-bottom: 2px solid var(--accent-blue);
    background-color: var(--bg-primary);
    border-radius: 10px 10px 0 0;
  }

  .chat-input-form {
    padding: 1.5rem;
    background-color: var(--bg-secondary);
    border-radius: 0 0 10px 10px;
  }

  .chat-input-group {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .chat-input {
    flex: 1;
    padding: 1rem;
    font-size: 1.1rem;
    border: 2px solid var(--accent-blue);
    border-radius: 25px;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    transition: border-color 0.3s ease;
  }

  .chat-input:focus {
    outline: none;
    border-color: var(--accent-pink);
    box-shadow: 0 0 0 0.2rem rgba(255, 0, 110, 0.25);
  }

  .chat-send-btn {
    border-radius: 25px;
    padding: 1rem 1.5rem;
    white-space: nowrap;
  }

  .chat-send-btn i {
    margin-right: 0.5rem;
  }

  /* Chat message styles */
  .user-message {
    text-align: right;
    margin: 1rem 0;
  }

  .user-message .message-content {
    display: inline-block;
    background-color: var(--accent-blue);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 20px 20px 5px 20px;
    max-width: 80%;
    font-size: 1.1rem;
  }

  .copilot-message {
    text-align: left;
    margin: 1rem 0;
  }

  .copilot-message .message-content {
    display: inline-block;
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    padding: 1rem 1.5rem;
    border-radius: 20px 20px 20px 5px;
    max-width: 80%;
    border: 2px solid var(--accent-pink);
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .chat-content {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .chat-box-container {
      height: 60vh;
    }
    
    .chat-input-group {
      flex-direction: column;
    }
    
    .chat-input,
    .chat-send-btn {
      width: 100%;
    }
  }
</style>

<script>
    document.getElementById('chat-form').addEventListener('submit', function(event) {
        event.preventDefault();
        const userInput = document.getElementById('user-input').value;
        const chatBox = document.getElementById('chat-box');
        
        // Get control panel values
        const debug = document.getElementById('debug') ? document.getElementById('debug').checked : false;
        const wordLimit = document.getElementById('word-limit').value;
        const condition = document.getElementById('condition').value;

        // Log values to console for debugging
        console.log('Debug:', debug);
        console.log('Word Limit:', wordLimit);
        console.log('Condition:', condition);
        console.log('Message:', userInput);

        // Display user message
        const userMessage = document.createElement('div');
        userMessage.className = 'user-message';
        userMessage.innerHTML = `<span class="message-text">${userInput}</span>`;
        chatBox.appendChild(userMessage);
        
        // Clear input field
        document.getElementById('user-input').value = '';
        
        // Display typing animation
        const typingAnimation = document.createElement('div');
        typingAnimation.className = 'typing-animation';
        typingAnimation.innerHTML = `<span class="message-text">.</span>`;
        chatBox.appendChild(typingAnimation);
        chatBox.scrollTop = chatBox.scrollHeight; // Scroll to the bottom

        // Animate typing animation
        const typingText = typingAnimation.querySelector('.message-text');
        let dots = 1;
        const typingInterval = setInterval(() => {
            dots = (dots % 3) + 1;
            typingText.textContent = '.'.repeat(dots);
        }, 500);

        // Send message to server
        fetch('{{ url_for("chat_with_copilot") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: new URLSearchParams({
                'message': userInput,
                'debug': debug,
                'headless': true,
                'word_limit': wordLimit,
                'condition': condition
            })
        })
        .then(response => response.json())
        .then(data => {
            // Remove typing animation
            clearInterval(typingInterval);
            chatBox.removeChild(typingAnimation);

            // Display Copilot response
            const copilotMessage = document.createElement('div');
            copilotMessage.className = 'copilot-message';
            if (data.response) {
                copilotMessage.innerHTML = `<span class="message-text">${data.response}</span>`;
            } else {
                copilotMessage.innerHTML = `<span class="message-text">{{ _('An error occurred while processing your request. Please try again later.') }}</span>`;
            }
            chatBox.appendChild(copilotMessage);
            chatBox.scrollTop = chatBox.scrollHeight; // Scroll to the bottom
        });
    });
</script>

<style>
    #chat-container {
        display: flex;
        width: 100%;
        max-width: 1000px;
        max-height: 1000px;
        height: 550px;
        margin: 0 auto;
        background-color: #333;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    }
    #control-panel {
        width: 30%;
        margin-right: 20px;
    }
    #control-form {
        display: flex;
        flex-direction: column;
    }
    #control-form label {
        margin-top: 10px;
    }
    #control-form input, #control-form textarea, #control-form button {
        margin-top: 5px;
        padding: 10px;
        border-radius: 5px;
        border: 1px solid #444;
        background-color: #222;
        color: white;
    }
    #control-form button {
        background-color: #007bff;
        cursor: pointer;
    }
    #control-form button:hover {
        background-color: #0056b3;
    }
    #chat-box-container {
        width: 70%;
    }
    #chat-box {
        border: 1px solid #444;
        padding: 10px;
        height: 450px;
        overflow-y: scroll;
        margin-bottom: 10px;
        background-color: #222;
        border-radius: 10px;
    }
    #chat-box::-webkit-scrollbar {
        width: 10px;
    }
    #chat-box::-webkit-scrollbar-track {
        background: #333;
        border-radius: 10px;
    }
    #chat-box::-webkit-scrollbar-thumb {
        background: #555;
        border-radius: 10px;
    }
    #chat-box::-webkit-scrollbar-thumb:hover {
        background: #777;
    }
    .user-message, .copilot-message, .typing-animation {
        width: 100%;
        display: flex;
        justify-content: flex-end;
        margin: 10px 0;
        padding: 10px;
        border-radius: 10px;
        background-color: #222;
    }
    .user-message .message-text {
        background-color: #007bff;
        color: white;
        padding: 5px;
        border-radius: 5px;
        max-width: 80%;
    }
    .copilot-message, .typing-animation {
        justify-content: flex-start;
    }
    .copilot-message .message-text, .typing-animation .message-text {
        background-color: #28a745;
        color: white;
        padding: 5px;
        border-radius: 5px;
        max-width: 80%;
    }
    #chat-form {
        display: flex;
    }
    #user-input {
        flex: 1;
        padding: 10px;
        border: 1px solid #444;
        border-radius: 10px;
        background-color: #222;
        color: white;
    }
    button {
        padding: 10px;
        border: none;
        background-color: #007bff;
        color: white;
        border-radius: 10px;
        cursor: pointer;
        margin-left: 10px;
    }
    button:hover {
        background-color: #0056b3;
    }
</style>
{% endblock %}

{% block title %}
{{ _('Chat with Copilot') }}
{% endblock %}

{% block head %}
{{ super() }}
{% endblock %}