{% extends "base.html.j2" %}
{% block title %} Lesson List {% endblock %}

{% block app_content %}

<h1>Lesson List</h1>
<ul>
    {% for lesson in lessons %}
        <li>
            <a href="{{ url_for('get_lesson', lesson_id=lesson.id) }}">Lesson {{ lesson.id }}: {{ lesson.title }}</a>
        </li>
    {% endfor %}
</ul>

{% endblock %}
